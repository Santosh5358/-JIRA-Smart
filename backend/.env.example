# ==============================
# JIRA Smart Dashboard — Environment Variables
# Copy this to .env and fill in your values.
# ==============================

# --- Server ---
SERVER_PORT=8085
SPRING_PROFILES_ACTIVE=dev

# --- JWT (REQUIRED in production — use a long random string) ---
JWT_SECRET=your-very-long-random-secret-key-at-least-64-chars-for-production-use
JWT_EXPIRATION_MS=28800000

# --- JIRA ---
JIRA_BASE_URL=https://jira.dedalus.com/
JIRA_API_TOKEN=

# --- GitHub ---
GITHUB_BASE_URL=https://github.com/dedalus-cis4u/
GITHUB_API_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_DEFAULT_ORG=dedalus-cis4u

# --- AI Provider ---
# Option A: OpenAI directly
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Option B: GitHub Models (free with Copilot Premium — uses your GitHub PAT)
#   OPENAI_BASE_URL=https://models.inference.ai.azure.com
#   OPENAI_API_KEY=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
OPENAI_BASE_URL=https://models.inference.ai.azure.com
OPENAI_API_KEY=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=8000

# --- CORS (comma-separated for multiple origins) ---
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- Logging ---
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_FILE=logs/jira-dashboard.log
